# ---------------------------------------------------------------------------
# etl-platform — environment template. Copy to `.env` and fill in.
# Never commit a real .env. Connection credentials for SOURCE/DESTINATION
# systems are NOT stored here — they go through the secrets abstraction.
# ---------------------------------------------------------------------------

# ---- Runtime -------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# ---- Control database (PostgreSQL) ---------------------------------------
# Used by @etl/database (Prisma). This is the platform's OWN metadata DB,
# not a customer source/destination.
DATABASE_URL=postgresql://etl:etl@localhost:5432/etl_control?schema=public

# ---- API -----------------------------------------------------------------
# One knob: the web app derives its API URL from API_PORT automatically, so
# changing API_PORT here is enough for `pnpm dev` to just work. If this port is
# taken on your machine, change it (e.g. 3077) and the web follows.
API_PORT=3001
API_HOST=0.0.0.0
# Only set NEXT_PUBLIC_API_URL to override the derived URL (e.g. a remote or
# staging API). Leave it unset for local dev.
# NEXT_PUBLIC_API_URL=http://localhost:3001

# ---- Auth ----------------------------------------------------------------
# The auth layer is provider-agnostic. `local` uses the built-in JWT provider.
AUTH_PROVIDER=local
JWT_SECRET=change-me-in-production-please-32chars-min
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ---- Secrets management --------------------------------------------------
# `env` = dev-only in-memory/env-backed store. `aws` = AWS Secrets Manager.
SECRETS_PROVIDER=env
AWS_REGION=eu-west-2
# For SECRETS_PROVIDER=env only. Real deployments use IAM, not these keys.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ---- Object storage (S3-compatible; MinIO in local dev) ------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=etl-platform
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# ---- Temporal (workflow orchestration) -----------------------------------
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=etl-main

# ---- AI service ----------------------------------------------------------
# Provider-agnostic. `anthropic` is the default provider.
AI_PROVIDER=anthropic
AI_DEFAULT_MODEL=claude-opus-4-8
AI_MAPPING_MODEL=claude-sonnet-5
AI_MAX_OUTPUT_TOKENS=8192
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ---- Web -----------------------------------------------------------------
WEB_PORT=3000
